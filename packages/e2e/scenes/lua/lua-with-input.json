{
  "definitions": {
    "@array": {
      "schema": {
        "inputs": [{ "name": "body", "type": "3d" }],
        "params": {
          "count": { "type": "int", "default": 3, "min": 1, "max": 16 },
          "spacing": { "type": "number", "default": 3.0 }
        },
        "output": "3d"
      },
      "code": "local parts = {}\nfor i = 1, params.count do\n  parts[#parts + 1] = geo.translate({offset = {(i - 1) * params.spacing, 0, 0}}, { inputs.body })\nend\nreturn geo.union({}, parts)\n"
    }
  },
  "doc": {
    "type": "lua",
