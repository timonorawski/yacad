{
  "name": "yacad",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "build:app": "pnpm --filter @yacad/studio build",
    "dev": "pnpm --filter @yacad/studio dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@yacad/eslint-config": "workspace:*",
    "@yacad/tsconfig": "workspace:*",
    "eslint": "^10.4.0",
    "fake-indexeddb": "^6.2.5",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
